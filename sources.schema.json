{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Agent Group Sources Configuration",
  "type": "object",
  "required": ["version", "sources"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Schema version"
    },
    "lastSync": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "Last synchronization timestamp"
    },
    "sources": {
      "type": "object",
      "description": "Sources organized by category",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["name", "url", "branch"],
          "properties": {
            "name": {
              "type": "string",
              "description": "Directory name for the repository"
            },
            "url": {
              "type": "string",
              "format": "uri",
              "description": "Git repository URL"
            },
            "branch": {
              "type": "string",
              "description": "Branch to clone"
            },
            "depth": {
              "type": "integer",
              "minimum": 1,
              "default": 1,
              "description": "Clone depth (1 for shallow)"
            },
            "description": {
              "type": "string",
              "description": "Brief description"
            },
            "addedAt": {
              "type": "string",
              "format": "date"
            },
            "notes": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Related learning notes"
            },
            "commit": {
              "type": "string",
              "description": "Current synced commit hash"
            }
          }
        }
      }
    }
  }
}
